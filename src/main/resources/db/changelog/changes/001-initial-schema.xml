<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001-create-account" author="hubertrm">
        <createTable tableName="account">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="creation_date" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="002-create-category" author="hubertrm">
        <createTable tableName="category">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="creation_date" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="003-create-transaction" author="hubertrm">
        <createTable tableName="transaction">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="amount" type="real">
                <constraints nullable="false"/>
            </column>
            <column name="date" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="varchar(255)"/>
            <column name="account_id" type="bigint"/>
            <column name="category_id" type="bigint"/>
            <column name="before_conversion" type="real"/>
            <column name="change_rate" type="real"/>
            <column name="currency" type="varchar(255)"/>
            <column name="holiday" type="varchar(255)"/>
            <column name="is_common" type="boolean"/>
            <column name="month" type="varchar(255)"/>
            <column name="nbr_of_actions" type="integer"/>
            <column name="ticker" type="varchar(255)"/>
            <column name="week_number" type="integer"/>
            <column name="year" type="integer"/>
            <column name="reference" type="bigint"/>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_transaction_account"
                baseTableName="transaction"
                baseColumnNames="account_id"
                referencedTableName="account"
                referencedColumnNames="id"/>

        <addForeignKeyConstraint
                constraintName="fk_transaction_category"
                baseTableName="transaction"
                baseColumnNames="category_id"
                referencedTableName="category"
                referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
